# 本地配置文件 - 不要提交到 GitHub！
# 复制此文件为 .env 并填入你的实际密钥

# GitHub Personal Access Token (需要 repo 权限)
# 获取地址: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# ModelScope API Token (用于 AI 图片生成)
# 获取地址: https://www.modelscope.cn/my/mynotebook/authorization
MODELSCOPE_TOKEN=your_modelscope_token_here

# 可选: 博客默认配置
BLOG_REPO=xinyanghuang7.github.io
BLOG_AUTHOR=ValueInvest
